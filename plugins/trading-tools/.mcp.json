{
  "mcpServers": {
    "alpaca": {
      "enabled": true,
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "SECRETS_DIR=\"${CODEX_SECRETS_DIR:-${CODEX_HOME:-$HOME/.codex}/secrets}\"; SECRET_FILE=\"$SECRETS_DIR/alpaca-live.env\"; UVX=\"$(command -v uvx || true)\"; if [ -z \"$UVX\" ] && [ -n \"${CODEX_LOCAL_BIN_DIR:-}\" ] && [ -x \"$CODEX_LOCAL_BIN_DIR/uvx\" ]; then UVX=\"$CODEX_LOCAL_BIN_DIR/uvx\"; fi; if [ -z \"$UVX\" ]; then echo \"uvx not found\" >&2; exit 127; fi; exec \"$UVX\" alpaca-mcp-server --env-file \"$SECRET_FILE\""
      ],
      "startup_timeout_sec": 120,
      "tool_timeout_sec": 180,
      "default_tools_approval_mode": "auto",
      "tools": {
        "update_account_config": {
          "approval_mode": "prompt"
        },
        "replace_order_by_id": {
          "approval_mode": "prompt"
        },
        "cancel_order_by_id": {
          "approval_mode": "prompt"
        },
        "cancel_all_orders": {
          "approval_mode": "prompt"
        },
        "place_stock_order": {
          "approval_mode": "prompt"
        },
        "place_crypto_order": {
          "approval_mode": "prompt"
        },
        "place_option_order": {
          "approval_mode": "prompt"
        },
        "close_position": {
          "approval_mode": "prompt"
        },
        "close_all_positions": {
          "approval_mode": "prompt"
        },
        "exercise_options_position": {
          "approval_mode": "prompt"
        },
        "do_not_exercise_options_position": {
          "approval_mode": "prompt"
        }
      }
    },
    "robinhood-trading": {
      "type": "http",
      "url": "https://agent.robinhood.com/mcp/trading",
      "startup_timeout_sec": 120,
      "tool_timeout_sec": 180,
      "default_tools_approval_mode": "auto"
    }
  }
}
